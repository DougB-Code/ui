{
  "id": "personal-assistant",
  "label": "Personal Assistant",
  "harness": {
    "id": "personal-pilot",
    "label": "Personal Pilot Harness",
    "api_base_url": "${AGENT_API_BASE_URL}",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "${AGENT_USER_ID}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/harness",
    "package_path": "./cmd/agent-awesome",
    "model_config": "${AGENTAWESOME_WORKSPACE_ROOT}/pilots/personal-assistant/model.yaml",
    "agent_config": "${AGENTAWESOME_WORKSPACE_ROOT}/pilots/personal-assistant/agent.yaml",
    "tool_config": "${AGENTAWESOME_WORKSPACE_ROOT}/pilots/personal-assistant/tool.yaml",
    "port": ${AGENT_API_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES}
  },
  "mcp_servers": [
    {
      "id": "memory-personal",
      "label": "Personal Memory",
      "kind": "memory",
      "endpoint": "${MEMORY_MCP_URL}",
      "health_url": "${MEMORY_HEALTH_URL}",
      "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/memory",
      "package_path": "./cmd/memoryd",
      "arguments": [
        "--addr",
        "${MEMORY_MCP_ADDR}",
        "--db",
        "${AGENTAWESOME_WORKSPACE_ROOT}/harness/build/pilot/personal-assistant/data/memory.db",
        "--data",
        "${AGENTAWESOME_WORKSPACE_ROOT}/harness/build/pilot/personal-assistant/data/memory-data"
      ],
      "auto_start": ${AUTO_START_LOCAL_SERVICES},
      "enabled": true
    },
    {
      "id": "tasks-personal",
      "label": "Personal Tasks",
      "kind": "tasks",
      "endpoint": "${TASKS_MCP_URL}",
      "health_url": "${TASKS_HEALTH_URL}",
      "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/tasks",
      "package_path": "./cmd/tasksd",
      "arguments": [
        "--addr",
        "${TASKS_MCP_ADDR}",
        "--db",
        "${AGENTAWESOME_WORKSPACE_ROOT}/harness/build/pilot/personal-assistant/data/tasks.db",
        "--memory-mcp",
        "${MEMORY_MCP_URL}"
      ],
      "auto_start": ${AUTO_START_LOCAL_SERVICES},
      "enabled": true
    }
  ]
}
